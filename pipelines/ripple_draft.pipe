{
  "components": [
    {
      "id": "in",
      "provider": "webhook",
      "config": {
        "mode": "Source",
        "parameters": {},
        "type": "webhook"
      }
    },
    {
      "id": "draft_llm",
      "provider": "llm_openai_api",
      "config": {
        "profile": "custom",
        "custom": {
          "model": "openai/gpt-4o-mini",
          "base_url": "https://models.github.ai/inference",
          "modelTotalTokens": 128000,
          "apikey": "${ROCKETRIDE_GITHUB_TOKEN}"
        },
        "parameters": {}
      },
      "input": [
        {
          "lane": "questions",
          "from": "in"
        }
      ]
    },
    {
      "id": "out",
      "provider": "response_answers",
      "config": {
        "laneName": "answers"
      },
      "input": [
        {
          "lane": "answers",
          "from": "draft_llm"
        }
      ]
    }
  ],
  "project_id": "8b4ef8a7-7bdd-41ec-95be-1151d981e771",
  "source": "in",
  "version": 1
}
