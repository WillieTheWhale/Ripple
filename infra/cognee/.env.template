# Copy values into the repository-root .env. Do not create a second secrets file here.
ROCKETRIDE_GITHUB_TOKEN=
COGNEE_USER=service@ripple.dev
COGNEE_PASSWORD=
COGNEE_JWT_SECRET=
COGNEE_RESET_SECRET=
COGNEE_VERIFY_SECRET=
COGNEE_API_KEY=

# Secure default: Cognee's multi-user-compatible embedded graph backend.
COGNEE_GRAPH_PROVIDER=kuzu
COGNEE_ACCESS_CONTROL=true

# Local Neo4j probe mode uses these values with COGNEE_ACCESS_CONTROL=false.
COGNEE_GRAPH_URL=bolt://neo4j-memory:7687
COGNEE_GRAPH_USER=neo4j
COGNEE_GRAPH_PASSWORD=memorypass
